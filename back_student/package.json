      "ts-node": "^10.9.2",
      "typescript": "^6.0.3"
   },
   "dependencies": {
      "@sentry/node": "^10.53.1",
      "@types/bcryptjs": "^2.4.6",
      "@types/body-parser": "^1.19.5",
      "@types/cors": "^2.8.17",
      "@types/express": "^5.0.0",
      "@types/helmet": "^4.0.0",
      "@types/jsonwebtoken": "^9.0.7",
      "@types/supertest": "^6.0.2",
      "@types/swagger-jsdoc": "^6.0.4",
      "bcryptjs": "^2.4.3",
      "body-parser": "^1.20.3",
      "class-transformer": "^0.5.1",
      "class-validator": "^0.14.1",
      "cors": "^2.8.5",
      "dotenv": "^16.4.7",
      "express": "^4.21.2",
      "helmet": "^8.0.0",
      "jsonwebtoken": "^9.0.2",
      "morgan": "^1.10.0",
      "mysql2": "^3.12.0",
      "prettier": "^3.4.2",
      "prom-client": "^15.1.3",
      "reflect-metadata": "^0.2.2",
      "supertest": "^7.0.0",
      "swagger-jsdoc": "^6.2.8",
      "swagger-stats": "^0.99.7",
