
# Example production .env (TEMPLATE)
# Copy this file to .env on the production host and populate all values with
# strong, environment-specific secrets. DO NOT commit the populated .env to VCS.

#########################
# MySQL / Database
#########################
MYSQL_ROOT_PASSWORD=REPLACE_WITH_STRONG_ROOT_PASSWORD
MYSQL_DATABASE=cia_db
MYSQL_USER=cia_user
MYSQL_PASSWORD=REPLACE_WITH_STRONG_DB_USER_PASSWORD
DB_PORT=3306

#########################
# App-level secrets
#########################
JWT_SECRET=REPLACE_WITH_LONG_RANDOM_JWT_SECRET
BCRYPT_SALT_ROUNDS=12

#########################
# Admin seed (only used on first migration/run)
#########################
# These are placeholders for initial seeding; ensure you change them to strong values or
# remove/change after the initial seed. Never use weak defaults in production.
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=REPLACE_WITH_STRONG_ADMIN_PASSWORD
DEFAULT_ADMIN_ROLE=ADMIN

#########################
# Ports and runtime
#########################
API_INTERNAL_PORT=3001
WEB_HOST_PORT=80

#########################
# CORS (Render API + Vercel web)
#########################
# Comma-separated browser origins allowed to call the API
ALLOWED_ORIGINS=http://localhost,http://localhost:80,http://localhost:8080

#########################
# Non-root user mapping for cia-api
#########################
# Map to the UID/GID of the 'service-web' user on the host (created during host prep)
SERVICE_USER_UID=1001
SERVICE_USER_GID=1001

#########################
# Build / image overrides (optional)
#########################
# If your CI publishes images to a registry (GHCR), set these to the full image name
# e.g. ghcr.io/ORG/cia-api:COMMIT_SHA
CIA_API_IMAGE=
CIA_WEB_IMAGE=

#########################
# Frontend config
#########################
REACT_APP_API_URL=http://localhost:3001

#########################
# Database canonical URL (optional)
#########################
DATABASE_URL=mysql://${MYSQL_USER}:${MYSQL_PASSWORD}@cia-db:${DB_PORT}/${MYSQL_DATABASE}

#########################
# Operational notes
#########################
# - Use a secrets manager or provisioning tool to write this file securely on the host
# - Lock permissions: chmod 600 .env and owned by root or the deploy user
# - Never put real secrets into your repository
