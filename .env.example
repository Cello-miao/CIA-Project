# ==========================================
# CIA Project - Environment Configuration Template
# ==========================================
# Copy this file to .env and fill in actual values
# DO NOT commit .env to version control

# ==========================================
# Database Configuration
# ==========================================
DB_HOST=db
DB_PORT=3306
DB_NAME=cia_db
DB_USER=cia_app
DB_PASSWORD=your_secure_password_here
DB_ROOT_PASSWORD=your_root_password_here

# ==========================================
# Application Configuration
# ==========================================
NODE_ENV=production
API_PORT=3000
LOG_LEVEL=info

# ==========================================
# Security Configuration
# ==========================================
JWT_SECRET=your_jwt_secret_key_change_this_to_random_string
JWT_EXPIRATION=24h

# ==========================================
# Initial Admin Account (for first deployment)
# ==========================================
# ⚠️  IMPORTANT: Set a strong password for the initial admin account
# If not set, a random password will be generated and shown in logs
INITIAL_ADMIN_PASSWORD=ChangeMe@2026!Secure

# ==========================================
# Frontend Configuration
# ==========================================
REACT_APP_API_URL=http://your_ec2_public_ip:3000
REACT_APP_ENV=production
