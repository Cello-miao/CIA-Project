# API Server Environment Configuration

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root
DB_NAME=prod_db

# Server
NODE_ENV=production
PORT=3000

# JWT
JWT_SECRET=your-secret-key-change-this

# Logging
LOG_LEVEL=info

# CORS
CORS_ORIGIN=https://example.com

# External APIs
API_TIMEOUT=30000
RETRY_ATTEMPTS=3
